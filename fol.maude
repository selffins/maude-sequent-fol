red FV(f^2[f^2[x{0}, x{1}], f^1[f^2[x{1}, x{2}]]]) .

--- test for free vars in a predicate

red FV(bot) .
red FV(P^1[x{0}]) .
red FV(P^1[f^1[x{0}]]) .
red FV(P^1[f^1[a{3}]]) .
red FV(P^2[x{0}, x{1}]) .
red FV(P^2[x{0}, x{0}]) .
red FV((P^1[x{0}]) /\ (Q^1[x{1}])) .
red FV((P^1[x{0}]) \/ (bot)) .
red FV((P^2[x{0}, x{1}]) -> (R^1[x{2}])) .
red FV(forall[x{0}]{P^1[x{0}]}) .
red FV(forall[x{0}]{P^1[x{1}]}) .
red FV(exists[x{1}]{P^2[x{0}, x{1}]}) .
red FV(forall[x{0}]{exists[x{1}]{(P^2[x{0}, x{2}]) /\ (Q^1[x{1}])}}) .

--- tests for substitution in a formula
red (P^1[x{0}]) [a{7} / x{0}] .
red (forall[x{0}]{P^1[x{0}]}) [a{7} / x{0}] .
red (forall[x{0}]{P^1[x{1}]}) [a{7} / x{1}] .

--- variable capture still happens
red (forall[x{0}]{P^1[x{1}]}) [x{0} / x{1}] .
