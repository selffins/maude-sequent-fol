--- simple propositional tests with srew
srew emptyC |--{0} (('a /\ 'b) -> 'a) using normalize .
srew emptyC |--{0} (('a /\ 'b) -> ('b /\ 'a)) using normalize .
srew emptyC |--{0} ((('a -> 'b) /\ ('b -> 'c)) -> ('a -> 'c)) using normalize .
srew emptyC |--{0} ((('a \/ 'b) /\ ('a -> 'c) /\ ('b -> 'c)) -> 'c) using normalize .
srew emptyC |--{0} (bot -> 'a) using normalize .

--- solves this long one (halted on g3cp.maude with search command!)
srew emptyC |--{0} ('a \/ ('b -> 'c) /\ ~ ('d /\ 'e /\ 'f) \/ ~ ('x <-> 'y)) <-> ('a \/ ('b -> 'c) /\ ~ ('d /\ 'e /\ 'f) \/ ~ ('x <-> 'y)) using normalize .

--- quantifier tests (easy)
srew emptyC |--{0} forall[x{0}]{(P^1[x{0}]) -> (P^1[x{0}])} using normalize .
srew forall[x{0}]{P^1[x{0}]} |--{0} P^1[x{0}] using solve .
srew P^1[x{0}] |--{0} exists[x{1}]{P^1[x{1}]} using solve .

--- can solve it once, but loops afterwards
srew [1] forall[x{0}]{(P^1[x{0}])} |--{1} exists[x{1}]{(P^1[x{1}])} using solve .
srew emptyC |--{0} forall[x{0}]{(P^1[x{0}]) -> (P^1[x{0}])} using solve .
eof

srew forall[x{0}]{(P^1[x{0}]) /\ (Q^1[x{0}])} |--{0} (P^1[x{0}]) using solve .

search [1] 'a /\ 'b |--{0} 'b /\ 'a =>* proved .
search [1] emptyC |--{0} 'a <-> 'a =>* proved .

--- tests for substitution

red a{0} [a{7} / x{0}] .
red x{0} [a{7} / x{0}] .
red x{1} [a{7} / x{0}] .

red f^1[x{0}] [a{9} / x{0}] .
red f^1[f^1[x{0}]] [a{9} / x{0}] .

red f^2[x{0}, x{1}] [a{5} / x{0}] .
red f^2[f^1[x{0}], f^2[x{0}, a{3}]] [f^1[a{8}] / x{0}] .

--- tests for free vars

red FV(a{0}) .

red FV(x{0}) .
red FV(x{7}) .

red FV(f^1[x{0}]) .
red FV(f^1[a{3}]) .

red FV(f^1[f^1[x{2}]]) .

red FV(f^2[x{0}, x{1}]) .
red FV(f^2[x{0}, x{0}]) .
red FV(f^2[a{9}, x{4}]) .
